# Required — OpenAI API key for story generation
OPENAI_API_KEY=

# Required — Supabase auth + saved repo scores (public client keys)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Required — server-only, bypasses RLS. Used to log every repo scan. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Optional — raises GitHub API rate limits for repo fetching
GITHUB_TOKEN=

# Optional — production rate limiting (recommended on Vercel)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Required to ingest job postings — shared secret checked against the
# x-refresh-secret header on POST /api/jobs/refresh. Generate any random string.
JOB_REFRESH_SECRET=
